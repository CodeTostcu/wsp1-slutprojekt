<body>
  <h2>Dina recept</h2>

  <h2>Kallrätt</h2>
  <ul>
    <% @recipes.each do |recipe| %>
      <% if recipe["category"].to_i == 1 && recipe["userid"] == session[:user_id] %>
        <li>
          <a href="/recipes/<%= recipe["id"]%>"><%= recipe['name'] %> </a>

          <form class='delete' action="/recipes/<%=recipe["id"]%>/delete" method="post" >
	           <input type="submit" value="Ta bort"> 
          </form>

          <form class='delete' action="/recipes/<%=recipe["id"]%>/edit" method="get" >
	          <input type="submit" value="Updatera">
          </form>

        </li>
      <% end %>
    <% end %>
  </ul>

  <h2>Varmrätt</h2>
  <ul>
    <% @recipes.each do |recipe| %>
      <% if recipe["category"].to_i == 0 && recipe["userid"] == session[:user_id] %>
        <li>
          <a href="/recipes/<%= recipe["id"]%>"><%= recipe['name'] %> </a>

            <form class='delete' action="/recipes/<%=recipe["id"]%>/delete" method="post" >
	           <input type="submit" value="Ta bort"> 
            </form>

            <form class='delete' action="/recipes/<%=recipe["id"]%>/edit" method="get" >
	            <input type="submit" value="Updatera">
            </form>
        </li>
      <% end %>
    <% end %>
  </ul>

  <a href="/recipes/new">Nytt recept</a>

</body>
</html>